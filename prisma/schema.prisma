generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────
// USERS & AUTH
// ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  role          String    @default("CUSTOMER") // ADMIN | CUSTOMER
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Optional for OAuth
  phone         String?
  address       String?
  city          String?
  orders        Order[]
  cartItems     CartItem[]
  cartVersion   Int       @default(0)
  couponUsages  CouponCustomerUsage[]
  accounts      Account[]
  securityTokens AccountSecurityToken[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([role, createdAt])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AccountSecurityToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // PASSWORD_RESET | EMAIL_VERIFICATION
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, type, expiresAt])
}

// ──────────────────────────────────────────────
// CATALOG
// ──────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Product {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  description    String
  price          Float
  compareAtPrice Float?           // Original price for "sale" display
  categoryId     String
  category       Category         @relation(fields: [categoryId], references: [id])
  variants       ProductVariant[]
  images         ProductImage[]
  orderItems     OrderItem[]
  isActive       Boolean          @default(true)
  isFeatured     Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([isActive, isFeatured, createdAt])
  @@index([categoryId, isActive, createdAt])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  sortOrder Int     @default(0)

  @@index([productId, sortOrder])
}

model ProductVariant {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  size          String?
  color         String?
  sku           String      @unique
  stock         Int         @default(0)
  priceOverride Float?      // Optional price override for this variant
  orderItems    OrderItem[]
  cartItems     CartItem[]

  @@index([productId])
}

// ──────────────────────────────────────────────
// CART (Server-side for abandoned cart tracking)
// ──────────────────────────────────────────────

model CartItem {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int            @default(1)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([userId, variantId])
}

// ──────────────────────────────────────────────
// ORDERS
// ──────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique // LC-20260413-001
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  subtotal        Float
  discount        Float       @default(0)
  total           Float
  status          String      @default("PENDING") // PENDING | CONFIRMED | SHIPPED | DELIVERED | CANCELLED
  shippingName    String
  shippingAddress String
  shippingCity    String
  shippingPhone   String
  trackingNumber  String?     // Manual tracking
  paymentMethod   String      // STRIPE | TRANSFER | ADDI | WHATSAPP
  paymentStatus   String      @default("PENDING") // PENDING | PAID | FAILED
  stripeSessionId String?
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([createdAt])
  @@index([userId, createdAt])
}

model OrderItem {
  id          String         @id @default(cuid())
  orderId     String
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?       @relation(fields: [productId], references: [id])
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  productName String         // Snapshot - won't change if product is modified
  productSize String?
  productColor String?
  quantity    Int
  unitPrice   Float

  @@index([orderId])
  @@index([productId])
}

// ──────────────────────────────────────────────
// COUPONS / DISCOUNTS
// ──────────────────────────────────────────────

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  type        String    // PERCENTAGE | FIXED
  value       Float     // e.g. 15 (%) or 10000 (COP)
  minPurchase Float?    // Minimum order amount
  maxUses     Int?      // null = unlimited
  maxUsesPerUser Int?   // null = unlimited per customer
  usedCount   Int       @default(0)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  orders      Order[]
  customerUsages CouponCustomerUsage[]
  createdAt   DateTime  @default(now())
}

model CouponCustomerUsage {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usedCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([couponId, userId])
  @@index([userId, couponId])
}
