# LilCake environment variables
# Copy this file to .env for shared defaults.
# For safe local development, add DATABASE_URL and DIRECT_URL overrides in .env.local
# with a dedicated schema (for example `schema=local_dev`) so localhost never writes
# into the same tables used by Vercel production.

# Shared PostgreSQL / Supabase connection:
# DATABASE_URL -> Transaction Pooler (:6543) for app queries
# DIRECT_URL -> Session Pooler (:5432) for Prisma CLI commands
# For direct IPv6 connections you can replace DIRECT_URL with db.<project-ref>.supabase.co:5432.
# In local development, override both in .env.local with a dedicated schema:
# DATABASE_URL="...:6543/postgres?pgbouncer=true&connection_limit=1&schema=local_dev"
# DIRECT_URL="...:5432/postgres?schema=local_dev"
DATABASE_URL="postgresql://postgres.your-project-ref:your-password@your-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.your-project-ref:your-password@your-region.pooler.supabase.com:5432/postgres"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-secret-here-with-at-least-32-characters"

GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
SMTP_FROM="LilCake <no-reply@example.com>"

STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Register your production endpoint in Stripe and copy its signing secret here.
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_ENABLED="false"

# Wompi Colombia payments.
# Keep disabled until webhook and sandbox checks pass in Vercel.
NEXT_PUBLIC_WOMPI_ENABLED="false"
WOMPI_ENVIRONMENT="sandbox"
NEXT_PUBLIC_WOMPI_PUBLIC_KEY="pub_test_..."
WOMPI_PRIVATE_KEY="prv_test_..."
WOMPI_EVENTS_SECRET="test_events_..."
WOMPI_INTEGRITY_SECRET="test_integrity_..."

NEXT_PUBLIC_WHATSAPP_NUMBER="573000000000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="LilCake"
NEXT_PUBLIC_SUPPORT_EMAIL="contacto@tudominio.com"

# Persistent product image uploads in Vercel.
# Required in production if admins need to upload files from the product form.
# In local development, uploads fall back to public/uploads/products when this is empty.
BLOB_READ_WRITE_TOKEN=""
