# LilCake environment variables
# Copy this file to .env and fill in the values

# Supabase local/dev:
# DATABASE_URL -> Transaction Pooler (:6543) for app queries
# DIRECT_URL -> Session Pooler (:5432) for Prisma CLI commands
# For direct IPv6 connections you can replace DIRECT_URL with db.<project-ref>.supabase.co:5432.
DATABASE_URL="postgresql://postgres.your-project-ref:your-password@your-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your-project-ref:your-password@your-region.pooler.supabase.com:5432/postgres"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-secret-here"

GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_ENABLED="false"

NEXT_PUBLIC_WHATSAPP_NUMBER="573000000000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="LilCake"
