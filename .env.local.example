# Safe local-only overrides for LilCake
# Copy these values into .env.local after configuring your shared .env.
# The important part is using a dedicated schema so localhost never writes
# into the same tables used by production on Vercel.

DEV_DB_SCHEMA="local_dev"
DATABASE_URL="postgresql://postgres.your-project-ref:your-password@your-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=local_dev"
DIRECT_URL="postgresql://postgres.your-project-ref:your-password@your-region.pooler.supabase.com:5432/postgres?schema=local_dev"

NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional local-only overrides
NEXT_PUBLIC_STRIPE_ENABLED="false"

# Optional: set this if you also want local uploads to go to Vercel Blob.
# Leave empty to keep local uploads in public/uploads/products.
BLOB_READ_WRITE_TOKEN=""
